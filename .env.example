# GEHLEN LANER Dashboard — Environment Variables
# Скопируй этот файл в .env и заполни своими значениями

# Baserow (JWT auth)
BASEROW_EMAIL=your@email.com
BASEROW_PASSWORD=your_password
BASEROW_TOKEN=your_api_token

# DeepSeek API (for AI analytics & debug agent)
DEEPSEEK_API_KEY=sk-your-key

# GitHub (for repo operations)
GITHUB_TOKEN=ghp_your_token

# Station SSH (for remote Ollama management)
STATION_PASS=your_password
