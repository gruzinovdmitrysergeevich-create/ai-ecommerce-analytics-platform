{
  "api_base_url": "https://api-seller.ozon.ru",
  "api_key_env": "OZON_CREDS",
  "report_name": "realization",
  "api_endpoint": "/v2/finance/realization",
  "method": "POST",
  "pagination_type": "none",
  "field_mapping": {
    "rowNumber": "integer",
    "item.sku": "integer",
    "item.offer_id": "text",
    "item.name": "text",
    "item.barcode": "text",
    "seller_price_per_instance": "number",
    "commission_ratio": "number",
    "delivery_commission.price_per_instance": "number",
    "delivery_commission.quantity": "integer",
    "delivery_commission.amount": "number",
    "delivery_commission.commission": "number",
    "delivery_commission.bonus": "number",
    "delivery_commission.compensation": "number",
    "delivery_commission.standard_fee": "number",
    "delivery_commission.bank_coinvestment": "number",
    "delivery_commission.stars": "number",
    "delivery_commission.pick_up_point_coinvestment": "number",
    "delivery_commission.total": "number",
    "return_commission.price_per_instance": "number",
    "return_commission.quantity": "integer",
    "return_commission.amount": "number",
    "return_commission.commission": "number",
    "return_commission.bonus": "number",
    "return_commission.compensation": "number",
    "return_commission.standard_fee": "number",
    "return_commission.bank_coinvestment": "number",
    "return_commission.stars": "number",
    "return_commission.pick_up_point_coinvestment": "number",
    "return_commission.total": "number"
  },
  "unique_key": "",
  "unique_key_fields": ["rowNumber", "item_sku"],
  "max_depth_days": 1095,
  "split_by_month": true,
  "batch_size": 1,
  "is_async": false,
  "rate_limit_per_sec": 5,
  "response_data_path": "result.rows",
  "pagination_config": {},
  "request_body_template": "{\"month\":{month},\"year\":{year}}",
  "template_vars": {
    "month": "from_month",
    "year": "from_year"
  }
}
