{
  "api_base_url": "https://api-seller.ozon.ru",
  "api_key_env": "OZON_CREDS",
  "report_name": "returns_list",
  "api_endpoint": "/v1/returns/list",
  "method": "POST",
  "pagination_type": "last_id",
  "field_mapping": {
    "id": "integer",
    "posting_number": "text",
    "return_reason_name": "text",
    "type": "text",
    "schema": "text",
    "product.sku": "integer",
    "product.offer_id": "text",
    "product.name": "text",
    "product.quantity": "integer",
    "product.price.price": "number",
    "product.commission_percent": "number",
    "logistic.return_date": "date",
    "logistic.final_moment": "text",
    "visual.status.display_name": "text",
    "visual.status.sys_name": "text"
  },
  "unique_key": "id",
  "max_depth_days": 1095,
  "split_by_month": true,
  "batch_size": 500,
  "is_async": false,
  "rate_limit_per_sec": 5,
  "response_data_path": "returns",
  "pagination_config": {"last_id_param": "last_id", "limit_param": "limit"},
  "request_body_template": "{\"filter\":{\"logistic_return_date\":{\"time_from\":\"{from_date}T00:00:00Z\",\"time_to\":\"{to_date}T23:59:59Z\"}},\"limit\":500}"
}