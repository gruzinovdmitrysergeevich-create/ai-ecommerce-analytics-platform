{
  "api_base_url": "https://seller-analytics-api.wildberries.ru",
  "api_key_env": "WB_TOKEN",
  "report_name": "sales_funnel",
  "api_endpoint": "/api/analytics/v3/sales-funnel/products",
  "method": "POST",
  "pagination_type": "offset",
  "field_mapping": {
    "product.nmId": "integer",
    "product.title": "text",
    "product.vendorCode": "text",
    "product.brandName": "text",
    "product.subjectName": "text",
    "statistic.selected.openCount": "integer",
    "statistic.selected.cartCount": "integer",
    "statistic.selected.orderCount": "integer",
    "statistic.selected.buyoutCount": "integer",
    "statistic.selected.buyoutSum": "number",
    "statistic.selected.cancelCount": "integer",
    "statistic.selected.avgPrice": "number",
    "statistic.selected.addToWishlist": "integer",
    "statistic.selected.conversions.addToCartPercent": "number",
    "statistic.selected.conversions.cartToOrderPercent": "number",
    "statistic.selected.conversions.buyoutPercent": "number"
  },
  "unique_key": "product.nmId",
  "max_depth_days": 365,
  "batch_size": 1000,
  "is_async": false,
  "rate_limit_per_sec": 3,
  "response_data_path": "data.products",
  "pagination_config": {"offset_param": "offset", "limit_param": "limit"},
  "request_body_template": "{\"selectedPeriod\":{\"start\":\"{from_date}\",\"end\":\"{to_date}\"},\"nmIds\":[]}"
}
